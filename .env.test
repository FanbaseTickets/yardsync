# YardSync Test Environment
# Safe to commit — test keys only
# Real secrets stay in .env.local (gitignored)
# Production secrets are in Vercel only

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — TEST MODE ONLY
# Real test key lives in .env.local
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_TEST_KEY
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_REPLACE_WITH_TEST_PRICE_ID
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=price_REPLACE_WITH_TEST_ANNUAL_ID

# Firebase — dev project (Level 2 separation completed 2026-06-14)
# Production (main → yardsyncapp.com) uses yardsync-41886 — set in Vercel.
# Preview + local Dev use yardsync-dev.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=yardsync-dev

# Twilio — same account, A2P approved
TWILIO_MESSAGING_SERVICE_SID=MG21e23c10d5d507045b0a1e263c0eb25b

# Feature flags
NEXT_PUBLIC_ENV=test
