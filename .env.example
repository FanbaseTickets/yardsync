# YardSync Environment Variables
# Copy this file to .env.local and fill in values
# Get values from: Vercel dashboard, Stripe, Firebase Console, Twilio, Anthropic

# ── APP ──────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yardsyncapp.com

# ── FIREBASE ─────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=yardsync-41886
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_ADMIN_PASSWORD=
# FIREBASE_API_KEY is read server-side; defaults to NEXT_PUBLIC_FIREBASE_API_KEY if absent.

# ── STRIPE ───────────────────────────────
# Test keys (sk_test_... / pk_test_...) for local and preview environments.
# Live keys (sk_live_... / pk_live_...) for production — set in Vercel only.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_SETUP=
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=

# ── TWILIO ───────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
# NEXT_PUBLIC_TWILIO_ENABLED — feature flag, set to "true" to enable SMS UI
NEXT_PUBLIC_TWILIO_ENABLED=true

# ── ANTHROPIC ────────────────────────────
ANTHROPIC_API_KEY=

# ── ADMIN ────────────────────────────────
ADMIN_PHONE_NUMBER=
ADMIN_EMAIL=
# NEXT_PUBLIC_ADMIN_EMAIL — used client-side for admin UI gating (must match ADMIN_EMAIL)
NEXT_PUBLIC_ADMIN_EMAIL=
CRON_SECRET=

# ── SENDGRID ─────────────────────────────
SENDGRID_API_KEY=
# Verified sender — must be configured in SendGrid before sends will succeed
SENDGRID_FROM_EMAIL=
