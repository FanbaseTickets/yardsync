rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@fanbasetickets.net';
    }
    match /users/{uid} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }
    match /subscriptions/{uid} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }
    match /clients/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /schedules/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /services/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /invoices/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /feePayments/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /icalEvents/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /smsStatus/{doc} {
      // SMS delivery status records written by the Twilio status-callback
      // handler (server-side, authed as admin via lib/firestoreRest.js).
      // Admin-only access — these docs contain client phone numbers and
      // would leak across contractors if reads were broad-authenticated.
      // When a contractor-facing UI for delivery status is built, replace
      // with a scoped rule (resource.data.gardenerUid == request.auth.uid)
      // or proxy reads through a server-side API endpoint.
      allow read, write: if isAdmin();
    }
    match /slugs/{slug} {
      // Public-URL slug resolver collection for the Smart Business Card
      // feature (see docs/SMART_BUSINESS_CARD_SPEC.md §1.4). Every read +
      // write path goes through server-side lib/firestoreRest.js
      // (admin-authed) — the public /join/[slug] page reads via the
      // server component, /api/slug/check uses firestoreRest, and
      // /api/slug/generate uses firestoreRest. Contractors never write
      // directly from the client SDK. Admin-only is sufficient.
      allow read, write: if isAdmin();
    }
    match /rateLimits/{slug} {
      // Per-slug spam throttle for the public intake form. Read-modify-
      // write happens server-side in /api/join/submit (admin-authed via
      // firestoreRest). Never touched by client code.
      allow read, write: if isAdmin();
    }
    match /referralCards/{doc} {
      // Founder referral-card profile shown on /grow (name, title, headshot
      // + visibility toggles). Read + write only via server-side
      // lib/firestoreRest.js (admin-authed): the admin editor writes it
      // through /api/admin/referral-card and /grow reads it server-side.
      // Never touched by client SDK. Admin-only is sufficient.
      allow read, write: if isAdmin();
    }
    match /settings/{doc} {
      // Platform-wide admin config (settings/platform: SMS-cron master switch,
      // future toggles). Read + write only via server-side lib/firestoreRest.js
      // (admin-authed): the admin dashboard writes it through
      // /api/admin/cron-control and the SMS cron reads it server-side. Never
      // touched by client SDK. Admin-only is sufficient.
      allow read, write: if isAdmin();
    }
    match /quotes/{doc} {
      // Quotes (F14) — every read/write goes through server-side
      // lib/firestoreRest.js (admin-authed): the contractor list + builder use
      // /api/quotes, and the public /quote/[id] page reads + the e-sign
      // accept/decline write via /api/quotes/[id]/*. Quotes hold client PII
      // (name/phone/email + signature IP), so broad-authenticated reads would
      // leak across contractors — admin-only, accessed only via the server.
      allow read, write: if isAdmin();
    }
  }
}
