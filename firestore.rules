rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@fanbasetickets.net';
    }
    match /users/{uid} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }
    match /subscriptions/{uid} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }
    match /clients/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /schedules/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /services/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /invoices/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /feePayments/{doc} {
      allow read, write: if isAdmin() || request.auth != null;
    }
    match /icalEvents/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /smsStatus/{doc} {
      // SMS delivery status records written by the Twilio status-callback
      // handler (server-side, authed as admin via lib/firestoreRest.js).
      // Read access is broad-authenticated so future contractor UI can
      // surface "delivered / undelivered" per their own outbound messages.
      allow read:  if isAdmin() || request.auth != null;
      allow write: if isAdmin();
    }
  }
}
