# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Allowlist: these env files contain NO secrets and ARE committed:
#   .env.test    — non-secret test/sandbox values for local dev
#   .env.example — documentation of every env var the app needs
!.env.test
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
YARDSYNC_MASTER_CODEBASE.txt
YARDSYNC_MASTER_CODEBASE_V2.txt
YARDSYNC_CLAUDE_IMPORT.md
